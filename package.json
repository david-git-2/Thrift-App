{
  "name": "thrift-app",
  "version": "0.0.1",
  "private": true,
  "description": "A Quasar Project",
  "keywords": [
    "quasar",
    "quasar-app",
    "quasar-app-vite",
    "quasar-cli",
    "vite",
    "vue",
    "vuejs"
  ],
  "author": "marceldavidbaroi <marceldavidbaroi@gmail.com>",
  "type": "module",
  "scripts": {
    "lint": "oxfmt && oxlint --fix",
    "lint:check": "oxfmt --check && oxlint",
    "dev": "quasar dev",
    "build": "quasar build",
    "typecheck": "vue-tsc --noEmit",
    "sync": "cd src-capacitor && npx cap sync android",
    "clean:android": "node scripts/clean-android-build.mjs",
    "build:android": "node scripts/clean-android-build.mjs && quasar build -m capacitor -T android",
    "build:android:debug": "node scripts/clean-android-build.mjs && quasar build -m capacitor -T android -d",
    "generate:icons": "node scripts/generate-app-icon.mjs",
    "postinstall": "quasar prepare --silent"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "@quasar/extras": "^2.0.0",
    "@supabase/supabase-js": "^2.108.2",
    "pinia": "^3.0.1",
    "quasar": "^2.20.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@quasar/app-vite": "^3.0.0-rc.3",
    "@types/node": "^22.19.11",
    "autoprefixer": "^10.4.27",
    "oxfmt": "^0.x",
    "oxlint": "^1.x",
    "oxlint-tsgolint": "^0.x",
    "sharp": "^0.35.1",
    "typescript": "^6.0.0",
    "vue-tsc": "^3.3.3"
  },
  "engines": {
    "node": ">= 26 || ^24 || ^22.12"
  },
  "productName": "Thrift app"
}
