VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_LOCAL_APP_URL=http://localhost:9001
VITE_PRODUCTION_APP_URL=https://your-pages-domain.pages.dev

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_unsigned_preset
# Root folder in Cloudinary (must match upload preset asset folder)
VITE_CLOUDINARY_THRIFT_FOLDER=thrift-inventory-images

# Google Drive backup is web-only — keep disabled on mobile.
VITE_GOOGLE_DRIVE_UPLOAD_ENABLED=false

# Native Android Google Sign-In (Web OAuth client ID from Google Cloud — NOT the Android client ID).
# Same Web client ID configured under Supabase Auth → Providers → Google.
VITE_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# ── Android release signing ───────────────────────────────────────────────────
# Read by src-capacitor/android/app/build.gradle at build time.
# Path is relative to src-capacitor/android/app/
# See docs/GOOGLE_SIGNIN_SHA_SETUP.md for full setup instructions.
RELEASE_STORE_FILE=../../release.keystore
RELEASE_STORE_PASSWORD=your_store_password
RELEASE_KEY_ALIAS=thriftapp
RELEASE_KEY_PASSWORD=your_key_password
